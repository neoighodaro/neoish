---
import { type LandingCopy, landingRuntime } from "../i18n/landing"

interface Props {
  lang: "en" | "de"
  copy: LandingCopy
}
const { lang, copy } = Astro.props
const runtime = landingRuntime(lang)

const canonical = new URL(Astro.url.pathname, Astro.site)
const ogImage = new URL("/img/og.png", Astro.site)
const ogImageAlt = "Founder. Engineer. Music maker (kinda.) — Neo Ighodaro's blog at neoighodaro.com"
const enUrl = new URL("/", Astro.site)
const deUrl = new URL("/de/", Astro.site)
---

<!doctype html>
<html lang={lang}>
  <head>
    <script is:inline>
      document.documentElement.classList.add("js", "is-loading")
      if ("scrollRestoration" in history) history.scrollRestoration = "manual"
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{copy.meta.title}</title>
    <meta name="description" content={copy.meta.description} />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="de" href={deUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Neo Ighodaro" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={copy.meta.title} />
    <meta property="og:description" content={copy.meta.description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content={lang === "de" ? "de_DE" : "en_US"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={copy.meta.title} />
    <meta name="twitter:description" content={copy.meta.description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Fraunces:opsz,wght@9..144,100..900&family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&family=Space+Grotesk:wght@400..700&display=swap"
      rel="stylesheet"
    />
    <script
      defer
      src="https://stats.ckx.sh/script.js"
      data-website-id="7a68588b-7669-4443-9414-dcfdcc78e0e2"></script>
    <link rel="stylesheet" href="/styles/landing.css" />
    <script is:inline define:vars={{ runtime }}>
      window.__LANDING_I18N__ = runtime
    </script>
  </head>
  <body>
    <slot />
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"
      integrity="sha384-HOvlOYPIs/zjoIkWUGXkVmXsjr8GuZLV+Q+rcPwmJOVZVpvTSXQChiN4t9Euv9Vc"
      crossorigin="anonymous"></script>
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js"
      integrity="sha384-P8VzCVnT9NBUkMrpcIZrJbA7EBjJvh/fJS6PmP+4nLIM284DtsImIv8D0fFjIkeh"
      crossorigin="anonymous"></script>
    <script is:inline src="/js/landing.js"></script>
  </body>
</html>
