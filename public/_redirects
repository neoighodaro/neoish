# Serve the Astro-generated sitemap at the conventional /sitemap.xml path.
# Must precede the language catch-all so crawlers aren't bounced to /de/.
/sitemap.xml   /sitemap-index.xml   200

# Legacy Next.js post URLs (/posts/<slug>) moved to /blog/<slug>; slugs are
# unchanged. 301 so search engines transfer ranking to the new path. Kept above
# the language catch-all so it wins for German-preferring visitors too.
/posts/*   /blog/:splat   301

# German pages serve as-is; first-match-wins shields them from the catch-all below.
/de/*   /de/:splat   200

# Send German-preferring visitors (nf_lang cookie, else Accept-Language) from any
# English path to its /de/ equivalent. Forced (!) so it overrides the static file
# that exists at every English path. 302 keeps the English URL canonical.
/*      /de/:splat   302!   Language=de
